---
import ProjectsLayout from '../layouts/ProjectsLayout.astro';
---

<ProjectsLayout title="Mis Proyectos">
    <section>
        <h2 class="text-xl font-bold text-accent-blue
                            hover:text-accent-blue-dark transition-colors duration-200 p-2 text-center">Proyectos Destacados</h2>

        {/* Contenedor de las tarjetas de proyectos */}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6 p-4"> {/* Ajusta el grid para las tarjetas */}
            {/* Tarjeta de Proyecto 1: Dashboard Analítico */}
            <a href="/dashboard" class="group block relative overflow-hidden rounded-lg shadow-xl cursor-pointer
                                      transform transition-all duration-300 ease-in-out
                                      hover:-translate-y-2 hover:shadow-2xl hover:scale-[1.01]"
                                      data-astro-prefetch> {/* data-astro-prefetch para navegación más rápida */}

                <div class="project-card relative p-6 md:p-8 flex flex-col md:flex-row items-center md:items-start gap-6 bg-gray-900">
                    <div class="flex-1 text-white">
                        <h3 class="text-2xl font-semibold text-accent-blue mb-2 group-hover:text-accent-blue-dark transition-colors duration-200">Proyecto 1: Dashboard Analítico</h3>
                        <p class="text-gray-300 mb-4">Dashboard interactivo para visualizar datos de ventas, construido con React y Chart.js. Permite análisis de KPIs y tendencias.</p>
                        {/* El enlace de texto original es reemplazado por el hover overlay */}
                    </div>
                    <div class="md:w-1/3 flex justify-center items-center">
                        <img src="../dashboard.jpg" alt="Miniatura Dashboard Analítico"
                             class="w-full max-w-[200px] md:max-w-full h-auto rounded-md object-cover border border-cyan-700/50
                                    transition-all duration-300 group-hover:blur-sm"/>
                    </div>
                    {/* Overlay para el efecto hover */}
                    <div class="project-overlay absolute inset-0 bg-black bg-opacity-70 flex items-center justify-center
                                 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                        <span class="text-white text-xl font-bold p-4 rounded-md border-2 border-accent-blue">Ver Proyecto</span>
                    </div>
                </div>
            </a>

            {/* Tarjeta de Proyecto 2: Aplicación Móvil */}
            <a href="https://example.com/mobile-app" target="_blank" rel="noopener noreferrer"
               class="group block relative overflow-hidden rounded-lg shadow-xl cursor-pointer
                      transform transition-all duration-300 ease-in-out
                      hover:-translate-y-2 hover:shadow-2xl hover:scale-[1.01]"
               data-astro-prefetch>

                <div class="project-card relative p-6 md:p-8 flex flex-col md:flex-row items-center md:items-start gap-6 bg-gray-900">
                    <div class="flex-1 text-white">
                        <h3 class="text-2xl font-semibold text-accent-blue mb-2 group-hover:text-accent-blue-dark transition-colors duration-200">Proyecto 2: Aplicación Móvil</h3>
                        <p class="text-gray-300 mb-4">App para gestionar tareas personales con React Native. Incluye autenticación de usuario y sincronización de datos.</p>
                    </div>
                    <div class="md:w-1/3 flex justify-center items-center">
                        <img src="/images/mobile-app-thumbnail.jpg" alt="Miniatura Aplicación Móvil"
                             class="w-full max-w-[200px] md:max-w-full h-auto rounded-md object-cover border border-cyan-700/50
                                    transition-all duration-300 group-hover:blur-sm"/>
                    </div>
                    <div class="project-overlay absolute inset-0 bg-black bg-opacity-70 flex items-center justify-center
                                 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                        <span class="text-white text-xl font-bold p-4 rounded-md border-2 border-accent-blue">Ver Proyecto</span>
                    </div>
                </div>
            </a>

            {/* Tarjeta de Proyecto 3: Dashboard Power BI */}
            <a href="https://app.powerbi.com/view?r=eyJrIjoiNDEzODA4NjEtMjk3Zi00MmExLTg3NzAtZDk4YTQ4NGExZGU5IiwidCI6IjYzODU0OTZkLWY3MDItNDA4YS1iNDlmLTA0ZTQ4YmJlM2M2MCIsImMiOjR9" 
               target="_blank" 
               rel="noopener noreferrer"
               class="group block relative overflow-hidden rounded-lg shadow-xl cursor-pointer
                      transform transition-all duration-300 ease-in-out
                      hover:-translate-y-2 hover:shadow-2xl hover:scale-[1.01]">

                <div class="project-card relative p-6 md:p-8 flex flex-col items-center gap-6 bg-gray-900">
                    <div class="flex-1 text-white w-full">
                        <h3 class="text-2xl font-semibold text-accent-blue mb-2 group-hover:text-accent-blue-dark transition-colors duration-200">Proyecto 3: Dashboard Power BI - Eva Final</h3>
                        <p class="text-gray-300 mb-4">Reporte interactivo de análisis de datos con visualizaciones dinámicas en Power BI.</p>
                    </div>
                    <div class="w-full flex justify-center items-center">
                        <iframe 
                            title="Eva_Final" 
                            width="100%" 
                            height="200" 
                            src="https://app.powerbi.com/view?r=eyJrIjoiNDEzODA4NjEtMjk3Zi00MmExLTg3NzAtZDk4YTQ4NGExZGU5IiwidCI6IjYzODU0OTZkLWY3MDItNDA4YS1iNDlmLTA0ZTQ4YmJlM2M2MCIsImMiOjR9" 
                            frameborder="0" 
                            allowFullScreen="true"
                            class="rounded-md border border-cyan-700/50 transition-all duration-300 group-hover:blur-sm pointer-events-none">
                        </iframe>
                    </div>
                    {/* Overlay para el efecto hover */}
                    <div class="project-overlay absolute inset-0 bg-black bg-opacity-70 flex items-center justify-center
                                 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                        <span class="text-white text-xl font-bold p-4 rounded-md border-2 border-accent-blue">Ver Proyecto</span>
                    </div>
                </div>
            </a>

            {/* Tarjeta de Proyecto 4: Gestor de Tareas Full Stack */}
            <a href="https://apptareas-app.netlify.app/" 
               target="_blank" 
               rel="noopener noreferrer"
               class="group block relative overflow-hidden rounded-lg shadow-xl cursor-pointer
                      transform transition-all duration-300 ease-in-out
                      hover:-translate-y-2 hover:shadow-2xl hover:scale-[1.01]">

                <div class="project-card relative p-6 md:p-8 flex flex-col md:flex-row items-center md:items-start gap-6 bg-gray-900">
                    <div class="flex-1 text-white">
                        <h3 class="text-2xl font-semibold text-accent-blue mb-2 group-hover:text-accent-blue-dark transition-colors duration-200">Proyecto 4: Gestor de Tareas Full Stack</h3>
                        <p class="text-gray-300 mb-4">Aplicación web completa con React + Flask + PostgreSQL, containerizada con Docker. Deploy en producción con CI/CD automático. Incluye CRUD, filtros dinámicos y UI moderna.</p>
                        {/* Stack Badges */}
                        <div class="flex flex-wrap gap-2 mb-3">
                            <span class="px-3 py-1 text-xs font-semibold bg-blue-500/20 text-blue-300 rounded-full border border-blue-500/50">React 18</span>
                            <span class="px-3 py-1 text-xs font-semibold bg-green-500/20 text-green-300 rounded-full border border-green-500/50">Flask</span>
                            <span class="px-3 py-1 text-xs font-semibold bg-purple-500/20 text-purple-300 rounded-full border border-purple-500/50">PostgreSQL</span>
                            <span class="px-3 py-1 text-xs font-semibold bg-cyan-500/20 text-cyan-300 rounded-full border border-cyan-500/50">Docker</span>
                        </div>
                        {/* GitHub Link */}
                        <div class="flex items-center gap-2 text-sm text-gray-400">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                            <span>GitHub</span>
                        </div>
                    </div>
                    <div class="md:w-1/3 flex justify-center items-center">
                        <img src="../tareas-app.jpg" alt="Miniatura Gestor de Tareas"
                             class="w-full max-w-[200px] md:max-w-full h-auto rounded-md object-cover border border-cyan-700/50
                                    transition-all duration-300 group-hover:blur-sm"/>
                    </div>
                    {/* Overlay para el efecto hover */}
                    <div class="project-overlay absolute inset-0 bg-black bg-opacity-70 flex items-center justify-center
                                 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                        <span class="text-white text-xl font-bold p-4 rounded-md border-2 border-accent-blue">Ver Proyecto</span>
                    </div>
                </div>
            </a>

            {/* Puedes añadir más tarjetas de proyecto aquí */}
        </div>
    </section>

    <style>
        /* Estilos generales para las tarjetas de proyecto */
        .project-card {
            /* Los estilos de borde y sombra ahora son clases de Tailwind en el 'a' o en el contenedor principal del card */
            /* Se mantiene el fondo y padding base */
            background: rgba(45, 45, 65, 0.9); /* Un fondo oscuro que contraste con el efecto neuronal */
            border: 1px solid #00aaff; /* Borde cyano */
            border-radius: 5px;
            /* Padding es manejado por Tailwind p-6 md:p-8 */
            /* margin-bottom ahora es gap-6 en el grid */
            /* box-shadow y transform son manejados por Tailwind en el a */
            /* transition también en el a */
        }

        /* Oculta los enlaces de texto individuales, ya que el click será en toda la tarjeta */
        .project-card a {
            display: none;
        }

        /*
         Los estilos de hover ahora se manejan con las clases 'group' y 'group-hover' de Tailwind
         El efecto de desenfoque de la imagen se logra con 'group-hover:blur-sm'
         El overlay 'Ver Proyecto' se logra con 'group-hover:opacity-100'
        */
    </style>
</ProjectsLayout>